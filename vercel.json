{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },

    { "source": "/ventas", "destination": "/ventas/index.html" },
    { "source": "/ventas.html", "destination": "/ventas/index.html" },

    { "source": "/lealtad", "destination": "/app/lealtad/index.html" },
    { "source": "/lealtad/:path*", "destination": "/app/lealtad/:path*" },

    { "source": "/tarjeta-lealtad", "destination": "/app/tarjeta-lealtad.html" },
    { "source": "/tarjeta-lealtad.html", "destination": "/app/tarjeta-lealtad.html" },

    { "source": "/assets/:path*", "destination": "/public/assets/:path*" },

    { "source": "/apartados", "destination": "/apartados/index.html" },
    { "source": "/apartados-historial", "destination": "/apartados-historial/index.html" },

    { "source": "/ticket", "destination": "/ticket/index.html" },
    { "source": "/ticket/:path*", "destination": "/ticket/index.html" },

    { "source": "/apartado/:path*", "destination": "/apartados/index.html" }
  ]
}
