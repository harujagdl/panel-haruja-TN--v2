{
  "version": 2,
  "rewrites": [
    {
      "source": "/tarjeta-lealtad.html",
      "destination": "/app/tarjeta-lealtad.html"
    },
    {
      "source": "/tarjeta-lealtad",
      "destination": "/app/tarjeta-lealtad.html"
    },
    {
      "source": "/ticket/:folio",
      "destination": "/ticket/index.html?folio=:folio"
    },
    {
      "source": "/apartado/:folio",
      "destination": "/apartados/index.html?folio=:folio"
    },
    {
      "source": "/apartado-pdf/:folio",
      "destination": "/apartado-pdf/index.html?folio=:folio"
    },
    {
      "source": "/lealtad",
      "destination": "/app/lealtad/index.html"
    },
    {
      "source": "/lealtad/manifest.json",
      "destination": "/app/lealtad/manifest.json"
    },
    {
      "source": "/lealtad/sw.js",
      "destination": "/app/lealtad/sw.js"
    },
    {
      "source": "/lealtad/:path*",
      "destination": "/app/lealtad/:path*"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
